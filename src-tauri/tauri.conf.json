{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pingnet",
  "version": "0.4.5",
  "identifier": "com.pingnet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pingnet",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://speed.cloudflare.com; font-src 'self' data:; img-src 'self' data: blob:; worker-src blob:; frame-src 'self' http://localhost:* http://127.0.0.1:* https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNFOTg1QzRGQzE1OTE4RTAKUldUZ0dGbkJUMXlZUGoxU1FpenJieURERDlJekdWZ0ZOM0ttUjg4eTBCWXBuVzRuWHN6YTJ1MkQK",
      "endpoints": [
        "https://github.com/soham-verma/pingnet/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
