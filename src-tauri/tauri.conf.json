{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pingnet",
  "version": "0.3.0",
  "identifier": "com.pingnet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pingnet",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.github.com https://speed.cloudflare.com; font-src 'self' data:; img-src 'self' data: blob:; worker-src blob:; frame-src http: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
