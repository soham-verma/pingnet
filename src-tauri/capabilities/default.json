{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Pingnet",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://github.com/**" },
        { "url": "vscode://**" },
        { "url": "cursor://**" }
      ]
    },
    "notification:default",
    "dialog:default",
    "dialog:allow-save"
  ]
}
